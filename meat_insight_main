<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>MEAT INSIGHT — 플랫폼</title>
<meta name="description" content="정육점·고깃집 창업·운영·폐업 원스톱 플랫폼. 매물 마켓, 공급사 직거래, 컨설팅, 지원금 신청."/>
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif+KR:wght@700&family=Noto+Sans+KR:wght@400;500;700&display=swap" rel="stylesheet"/>
<style>
*{box-sizing:border-box;margin:0;padding:0;}
html,body{overflow-x:hidden;}
:root{
  --n:#0B1628;--n2:#0F1E3D;--n3:#162444;
  --g:#C9A84C;--g2:#E2C06A;--g3:#F0E8C8;--g4:rgba(201,168,76,.12);
  --cr:#F7F4ED;--cr2:#EDE9DC;--cr3:#E5DFD0;
  --ink:#0A0A0A;--i2:#2D2D2D;--i3:#666;
  --bd:#D8D4C0;--bd2:#C9C0AC;
  --w:#fff;
  --sans:'Noto Sans KR',sans-serif;
  --serif:'Noto Serif KR',serif;
  --r:12px;--rl:18px;--rxl:24px;
}
body{font-family:var(--sans);background:var(--cr);color:var(--ink);font-size:16px;line-height:1.7;padding-top:60px;}
.pg{display:none;}.pg.on{display:block;min-height:calc(100vh - 60px);padding-bottom:80px;}

/* ── NAV ── */
.nav{position:fixed;top:0;left:0;right:0;z-index:1000;height:60px;background:var(--n);border-bottom:1px solid rgba(201,168,76,.15);display:flex;align-items:center;justify-content:space-between;padding:0 24px;}
.nav-logo{display:flex;flex-direction:column;gap:1px;cursor:pointer;}
.nav-logo-main{font-family:var(--serif);font-size:16px;color:var(--w);letter-spacing:1.5px;}
.nav-logo-sub{font-size:9px;color:var(--g);letter-spacing:3px;text-transform:uppercase;}
.nav-links{display:flex;gap:2px;}
.nb{padding:7px 12px;font-size:13px;border-radius:8px;border:none;background:none;color:rgba(255,255,255,.5);cursor:pointer;font-family:var(--sans);transition:all .2s;letter-spacing:.2px;}
.nb:hover,.nb.on{background:rgba(201,168,76,.15);color:var(--g);}
.nav-cta{background:var(--g);color:var(--n);padding:8px 18px;border-radius:8px;border:none;font-size:13px;font-weight:700;cursor:pointer;font-family:var(--sans);transition:all .2s;letter-spacing:.3px;}
.nav-cta:hover{background:var(--g2);}

/* ── 홈 히어로 ── */
.hero{background:var(--n);padding:40px 24px 36px;position:relative;overflow:hidden;}
.hero-glow{position:absolute;width:400px;height:400px;border-radius:50%;background:radial-gradient(circle,rgba(201,168,76,.1),transparent 70%);top:-100px;right:-80px;pointer-events:none;}
.hero-eyebrow{display:flex;align-items:center;gap:10px;margin-bottom:16px;}
.hero-ey-line{width:24px;height:1px;background:var(--g);}
.hero-ey-txt{font-size:10px;color:var(--g);letter-spacing:4px;text-transform:uppercase;}
.trust-row{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:20px;}
.trust-chip{display:flex;align-items:center;gap:6px;background:rgba(201,168,76,.1);border:1px solid rgba(201,168,76,.25);border-radius:20px;padding:5px 12px;}
.trust-dot{width:5px;height:5px;border-radius:50%;background:var(--g);flex-shrink:0;}
.trust-txt{font-size:12px;color:rgba(255,255,255,.8);font-weight:500;}
.hero h1{font-family:var(--serif);font-size:30px;color:var(--w);line-height:1.35;margin-bottom:12px;}
.hero h1 em{color:var(--g);font-style:normal;}
.hero-sub{font-size:15px;color:rgba(255,255,255,.6);line-height:1.8;margin-bottom:24px;}
.hero-search{display:flex;background:rgba(255,255,255,.08);border:1px solid rgba(201,168,76,.3);border-radius:12px;overflow:hidden;margin-bottom:14px;}
.hero-search input{flex:1;padding:13px 18px;background:none;border:none;font-size:15px;color:var(--w);font-family:var(--sans);outline:none;}
.hero-search input::placeholder{color:rgba(255,255,255,.3);}
.hero-search button{padding:13px 20px;background:var(--g);color:var(--n);border:none;font-size:14px;font-weight:700;cursor:pointer;font-family:var(--sans);}
.filter-chips{display:flex;gap:8px;flex-wrap:wrap;}
.fchip{padding:7px 16px;border:1px solid rgba(201,168,76,.3);border-radius:20px;font-size:13px;color:rgba(255,255,255,.6);cursor:pointer;background:none;font-family:var(--sans);transition:all .2s;}
.fchip.on,.fchip:hover{border-color:var(--g);color:var(--g);background:rgba(201,168,76,.08);}

/* ── 서비스 스트립 ── */
.svc-strip{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:1px;background:var(--bd);}
.svc-item{background:var(--cr);padding:20px 12px 18px;text-align:center;cursor:pointer;border-bottom:3px solid transparent;transition:all .2s;}
.svc-item:hover{background:var(--w);border-bottom-color:var(--g);}
.svc-num{font-size:10px;color:var(--g);letter-spacing:2px;margin-bottom:8px;font-weight:500;}
.svc-ico{width:44px;height:44px;border-radius:12px;margin:0 auto 10px;display:flex;align-items:center;justify-content:center;}
.svc-t{font-size:14px;font-weight:700;color:var(--n2);margin-bottom:3px;}
.svc-d{font-size:12px;color:var(--i3);line-height:1.5;}

/* ── 스탯 바 ── */
.stat-bar{display:grid;grid-template-columns:repeat(4,1fr);background:var(--n2);gap:1px;}
.stat-cell{background:var(--n2);padding:18px 12px;text-align:center;}
.stat-n{font-family:var(--serif);font-size:22px;color:var(--w);font-weight:700;}
.stat-l{font-size:11px;color:var(--g);margin-top:3px;letter-spacing:.8px;font-weight:500;}

/* ── 섹션 ── */
.sec{padding:24px 20px;}
.sec-hd{display:flex;align-items:baseline;justify-content:space-between;margin-bottom:16px;}
.sec-title{font-family:var(--serif);font-size:18px;color:var(--ink);}
.sec-more{font-size:13px;color:var(--g);cursor:pointer;font-weight:500;}
.divider{height:1px;background:var(--bd);margin:0 20px;}

/* ── 매물 그리드 ── */
.listing-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:14px;}
.lc{background:var(--w);border:1px solid var(--bd);border-radius:var(--rl);overflow:hidden;cursor:pointer;transition:all .2s;}
.lc:hover{border-color:var(--g);transform:translateY(-2px);box-shadow:0 8px 24px rgba(0,0,0,.08);}
.lc-thumb{height:96px;background:var(--cr2);display:flex;align-items:center;justify-content:center;border-bottom:1px solid var(--bd);position:relative;}
.lc-thumb-inner{width:40px;height:40px;background:var(--cr3);border-radius:10px;}
.lc-premium{position:absolute;top:8px;left:8px;background:var(--g);color:var(--n);font-size:9px;font-weight:700;padding:2px 8px;border-radius:4px;letter-spacing:.5px;}
.lc-body{padding:13px;}
.lc-tags{display:flex;gap:5px;margin-bottom:7px;flex-wrap:wrap;}
.lc-tag{font-size:10px;padding:3px 8px;border-radius:4px;font-weight:500;}
.tag-store{background:rgba(201,168,76,.15);color:#5A4A00;}
.tag-item{background:rgba(15,30,61,.08);color:var(--n2);}
.tag-food{background:#E8F5E9;color:#1B5E20;}
.tag-new{background:var(--g);color:var(--n);}
.lc-title{font-size:14px;font-weight:700;color:var(--n2);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;margin-bottom:3px;}
.lc-sub{font-size:12px;color:var(--i3);margin-bottom:8px;}
.lc-price{font-size:15px;font-weight:700;color:var(--ink);}
.lc-price small{font-size:11px;color:var(--i3);font-weight:400;}
.lc-foot{display:flex;justify-content:space-between;margin-top:8px;padding-top:8px;border-top:1px solid var(--bd);}
.lc-loc{font-size:11px;color:var(--i3);}
.lc-ago{font-size:11px;color:var(--g);font-weight:500;}

/* ── 컨설팅 카드 ── */
.consult-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:14px;}
.cc{background:var(--w);border:1px solid var(--bd);border-radius:var(--rl);padding:18px;cursor:pointer;transition:all .2s;}
.cc:hover{border-color:var(--g);box-shadow:0 4px 16px rgba(201,168,76,.12);}
.cc-badge{display:inline-block;font-size:10px;padding:3px 10px;border-radius:4px;margin-bottom:10px;font-weight:700;letter-spacing:.5px;text-transform:uppercase;}
.badge-report{background:var(--g3);color:#5A4A00;}
.badge-consult{background:rgba(15,30,61,.08);color:var(--n2);}
.cc-title{font-size:15px;font-weight:700;color:var(--n2);margin-bottom:5px;}
.cc-desc{font-size:13px;color:var(--i3);line-height:1.6;margin-bottom:12px;}
.cc-price{font-family:var(--serif);font-size:18px;color:var(--n2);}
.cc-price small{font-size:12px;color:var(--i3);font-weight:400;font-family:var(--sans);}

/* ── 공급사 배너 ── */
.supply-banner{background:var(--n);border-radius:var(--rl);margin:0 20px 24px;padding:22px;}
.sb-top{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:18px;}
.sb-ey{font-size:10px;color:var(--g);letter-spacing:3px;margin-bottom:6px;font-weight:500;}
.sb-title{font-family:var(--serif);font-size:17px;color:var(--w);margin-bottom:4px;}
.sb-sub{font-size:13px;color:rgba(255,255,255,.5);}
.sb-btn{background:var(--g);color:var(--n);border:none;border-radius:8px;padding:9px 16px;font-size:13px;font-weight:700;cursor:pointer;font-family:var(--sans);white-space:nowrap;transition:all .2s;}
.sb-btn:hover{background:var(--g2);}
.sb-specs{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:rgba(201,168,76,.2);border-radius:10px;overflow:hidden;}
.sb-spec{background:rgba(255,255,255,.04);padding:12px;text-align:center;}
.sb-spec-n{font-family:var(--serif);font-size:15px;color:var(--g);margin-bottom:2px;}
.sb-spec-l{font-size:11px;color:rgba(255,255,255,.4);}

/* ── 페이지 헤더 ── */
.page-hdr{background:var(--n);padding:14px 20px;display:flex;align-items:center;gap:12px;cursor:pointer;border-bottom:1px solid rgba(201,168,76,.15);}
.page-hdr-back{color:var(--g);font-size:18px;font-weight:700;line-height:1;}
.page-hdr-title{font-family:var(--serif);font-size:15px;color:var(--w);}

/* ── 탭 ── */
.tab-bar{display:flex;background:var(--cr2);border-bottom:1px solid var(--bd);}
.tab-btn{flex:1;padding:14px;text-align:center;font-size:14px;color:var(--i3);cursor:pointer;border:none;background:none;font-family:var(--sans);border-bottom:2px solid transparent;transition:all .2s;font-weight:500;}
.tab-btn.on{color:var(--g);border-bottom-color:var(--g);background:var(--cr);}

/* ── 상품 카드 ── */
.p-body{padding:20px;}
.p-card{background:var(--w);border:1px solid var(--bd);border-radius:var(--rl);padding:22px;margin-bottom:16px;transition:all .2s;}
.p-card:hover{border-color:var(--g);box-shadow:0 4px 20px rgba(0,0,0,.06);}
.p-badge{display:inline-block;font-size:10px;padding:3px 10px;border-radius:4px;margin-bottom:12px;font-weight:700;letter-spacing:.5px;text-transform:uppercase;}
.p-title{font-family:var(--serif);font-size:18px;color:var(--ink);margin-bottom:8px;}
.p-desc{font-size:14px;color:var(--i2);line-height:1.8;margin-bottom:16px;}
.p-includes{margin-bottom:16px;}
.p-inc{display:flex;align-items:center;gap:10px;font-size:14px;color:var(--i2);padding:6px 0;border-bottom:1px solid var(--cr3);}
.p-inc:last-child{border:none;}
.p-inc-dot{width:18px;height:18px;background:var(--n2);border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.p-inc-dot::after{content:'✓';font-size:9px;color:var(--g);}
.p-price{font-family:var(--serif);font-size:22px;color:var(--n2);margin-bottom:14px;}
.p-price small{font-size:13px;color:var(--i3);font-family:var(--sans);font-weight:400;}
.btn-apply{width:100%;padding:14px;background:var(--n2);color:var(--g);border:none;border-radius:10px;font-size:15px;font-weight:700;cursor:pointer;font-family:var(--sans);transition:all .2s;letter-spacing:.3px;}
.btn-apply:hover{background:var(--n3);}

/* ── 계산기 ── */
.calc-tabs{display:flex;gap:8px;margin-bottom:18px;flex-wrap:wrap;}
.ct{padding:8px 16px;border:1px solid var(--bd2);border-radius:20px;font-size:13px;color:var(--i2);cursor:pointer;background:var(--w);font-family:var(--sans);transition:all .2s;font-weight:500;}
.ct.on{background:var(--n2);border-color:var(--n2);color:var(--g);font-weight:700;}
.calc-card{background:var(--w);border:1px solid var(--bd);border-radius:var(--rl);padding:20px;}
.calc-label{font-size:13px;color:var(--i2);font-weight:600;margin-bottom:6px;display:block;letter-spacing:.2px;}
.calc-input{width:100%;padding:11px 14px;border:1.5px solid var(--bd2);border-radius:10px;font-size:15px;font-family:var(--sans);background:var(--cr);color:var(--ink);margin-bottom:14px;transition:border-color .2s;}
.calc-input:focus{outline:none;border-color:var(--g);}
.r2{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
.result-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-top:16px;}
.result-card{background:var(--cr);border-radius:10px;padding:14px;border-left:3px solid var(--g);}
.result-label{font-size:11px;color:var(--i3);margin-bottom:4px;letter-spacing:.5px;text-transform:uppercase;font-weight:500;}
.result-value{font-family:var(--serif);font-size:18px;color:var(--n2);font-weight:700;}

/* ── 공급사 디렉토리 ── */
.dir-hero{background:var(--n);padding:24px 20px 22px;}
.dir-ey{display:flex;align-items:center;gap:8px;margin-bottom:12px;}
.dir-ey-line{width:18px;height:1px;background:var(--g);}
.dir-ey-txt{font-size:10px;color:var(--g);letter-spacing:3px;text-transform:uppercase;}
.dir-title{font-family:var(--serif);font-size:22px;color:var(--w);margin-bottom:6px;}
.dir-sub{font-size:14px;color:rgba(255,255,255,.5);line-height:1.7;margin-bottom:18px;}
.dir-stats{display:flex;gap:24px;}
.dir-stat-n{font-family:var(--serif);font-size:20px;color:var(--g);}
.dir-stat-l{font-size:11px;color:rgba(255,255,255,.4);margin-top:2px;}
.ad-banner{margin:16px 16px 0;background:linear-gradient(135deg,var(--n2),var(--n3));border:1px solid rgba(201,168,76,.25);border-radius:14px;padding:16px 18px;display:flex;align-items:center;justify-content:space-between;cursor:pointer;transition:all .2s;}
.ad-banner:hover{border-color:rgba(201,168,76,.5);}
.ad-left{display:flex;align-items:center;gap:14px;}
.ad-logo{width:48px;height:48px;background:rgba(255,255,255,.08);border-radius:10px;display:flex;align-items:center;justify-content:center;border:1px solid rgba(201,168,76,.2);}
.ad-logo-txt{font-family:var(--serif);font-size:9px;color:var(--g);text-align:center;line-height:1.4;font-weight:700;}
.ad-badge{display:inline-block;font-size:9px;background:var(--g);color:var(--n);padding:2px 8px;border-radius:3px;font-weight:700;letter-spacing:.5px;margin-bottom:5px;}
.ad-name{font-size:14px;font-weight:700;color:var(--w);margin-bottom:2px;}
.ad-desc{font-size:12px;color:rgba(255,255,255,.45);}
.ad-tags{display:flex;gap:5px;margin-top:6px;flex-wrap:wrap;}
.ad-tag{font-size:10px;padding:2px 8px;border-radius:3px;background:rgba(255,255,255,.06);color:rgba(255,255,255,.5);border:1px solid rgba(255,255,255,.08);}
.ad-btn{background:var(--g);color:var(--n);border:none;border-radius:8px;padding:9px 16px;font-size:12px;font-weight:700;cursor:pointer;font-family:var(--sans);white-space:nowrap;transition:all .2s;}
.filter-bar{background:var(--cr);border-bottom:1px solid var(--bd);padding:12px 16px;display:flex;gap:8px;flex-wrap:wrap;align-items:center;}
.filter-lbl{font-size:10px;color:var(--i3);letter-spacing:1px;text-transform:uppercase;margin-right:2px;font-weight:600;}
.sup-grid{padding:16px;display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:12px;}
.sc{background:var(--w);border:1px solid var(--bd);border-radius:var(--rl);overflow:hidden;cursor:pointer;transition:all .2s;}
.sc:hover{border-color:var(--g);box-shadow:0 4px 16px rgba(0,0,0,.08);}
.sc.featured{border:2px solid var(--g);}
.sc-head{background:var(--cr2);padding:14px;display:flex;align-items:flex-start;gap:12px;border-bottom:1px solid var(--bd);}
.sc-logo{width:42px;height:42px;border-radius:8px;background:var(--w);border:1px solid var(--bd);display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.sc-logo-txt{font-family:var(--serif);font-size:8px;color:var(--n2);text-align:center;line-height:1.3;font-weight:700;}
.sc-badges{display:flex;gap:4px;margin-bottom:5px;flex-wrap:wrap;}
.badge-ft{font-size:9px;background:var(--g);color:var(--n);padding:2px 7px;border-radius:3px;font-weight:700;}
.badge-vf{font-size:9px;background:#DCFCE7;color:#166534;padding:2px 7px;border-radius:3px;font-weight:500;}
.badge-ad{font-size:9px;background:var(--g3);color:#5A4A00;padding:2px 7px;border-radius:3px;font-weight:500;}
.sc-name{font-size:14px;font-weight:700;color:var(--n2);margin-bottom:2px;}
.sc-region{font-size:11px;color:var(--i3);}
.sc-body{padding:13px;}
.sc-cats{display:flex;gap:5px;flex-wrap:wrap;margin-bottom:8px;}
.scat{font-size:11px;padding:3px 9px;border-radius:4px;background:var(--cr2);color:var(--i2);font-weight:500;}
.sc-desc{font-size:12px;color:var(--i2);line-height:1.6;margin-bottom:10px;}
.sc-specs{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--bd);border-radius:8px;overflow:hidden;margin-bottom:10px;}
.sc-spec{background:var(--cr);padding:8px 6px;text-align:center;}
.sc-spec-n{font-family:var(--serif);font-size:13px;color:var(--n2);margin-bottom:1px;font-weight:700;}
.sc-spec-l{font-size:10px;color:var(--i3);}
.sc-foot{display:flex;gap:7px;}
.btn-contact{flex:1;padding:10px;background:var(--n2);color:var(--g);border:none;border-radius:8px;font-size:12px;font-weight:700;cursor:pointer;font-family:var(--sans);transition:all .2s;}
.btn-contact:hover{background:var(--n3);}
.btn-detail{padding:10px 13px;background:var(--w);border:1.5px solid var(--bd2);border-radius:8px;font-size:12px;color:var(--i2);cursor:pointer;font-family:var(--sans);transition:all .2s;}
.btn-detail:hover{border-color:var(--g);color:var(--g);}
.join-cta{margin:4px 16px 24px;background:var(--n);border-radius:var(--rl);padding:22px;}
.join-top{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:18px;}
.join-title{font-family:var(--serif);font-size:17px;color:var(--w);margin-bottom:5px;}
.join-sub{font-size:13px;color:rgba(255,255,255,.45);line-height:1.6;}
.btn-join{background:var(--g);color:var(--n);border:none;border-radius:8px;padding:10px 18px;font-size:13px;font-weight:700;cursor:pointer;font-family:var(--sans);white-space:nowrap;transition:all .2s;}
.btn-join:hover{background:var(--g2);}
.join-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:rgba(201,168,76,.2);border-radius:10px;overflow:hidden;}
.join-stat{background:rgba(255,255,255,.04);padding:12px 8px;text-align:center;}
.join-stat-n{font-family:var(--serif);font-size:15px;color:var(--g);}
.join-stat-l{font-size:10px;color:rgba(255,255,255,.35);margin-top:2px;}

/* ── 폐업 철거 ── */
.closure-hero{background:var(--n);padding:24px 20px;}
.cl-hero-title{font-family:var(--serif);font-size:22px;color:var(--w);margin-bottom:6px;}
.cl-hero-sub{font-size:14px;color:rgba(255,255,255,.5);}
.steps{padding:20px;}
.step{display:flex;gap:16px;margin-bottom:20px;}
.step-bubble{width:36px;height:36px;border-radius:50%;background:var(--n2);border:2px solid var(--g);color:var(--g);font-size:13px;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-family:var(--serif);}
.step-content{}
.step-title{font-size:16px;font-weight:700;color:var(--ink);margin-bottom:5px;}
