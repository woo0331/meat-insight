      <div class="r2-form"><div><label class="form-label">권리금 (만원)</label><input class="form-input" placeholder="없으면 0"/></div><div><label class="form-label">보증금 (만원)</label><input class="form-input" placeholder="만원 단위"/></div></div>
      <div class="r2-form"><div><label class="form-label">월세 (만원)</label><input class="form-input" placeholder="만원 단위"/></div><div><label class="form-label">면적 (㎡)</label><input class="form-input" placeholder="예: 66"/></div></div>
    </div>
    <div class="form-block">
      <div class="form-block-title">사진 · 설명</div>
      <div class="photo-drop"><div class="photo-drop-icon">+</div><div class="photo-drop-text">사진 추가 (최대 10장 · JPG, PNG)</div></div>
      <div style="height:12px;"></div>
      <label class="form-label">매물 설명</label>
      <textarea class="form-input" rows="3" placeholder="단골 현황, 장비 상태, 양도 이유 등"></textarea>
      <label class="form-label">연락처 <em>*</em></label>
      <input class="form-input" placeholder="010-0000-0000"/>
    </div>
    <button class="btn-submit" onclick="alert('등록이 완료되었습니다!\n\n담당자가 확인 후 1일 내 연락드립니다.')">무료로 등록하기</button>
  </div>
</div>

<!-- ═══ 마이페이지 ═══ -->
<div class="pg" id="pg-m">
  <div class="page-hdr" onclick="go('h')"><span class="page-hdr-back">←</span><span class="page-hdr-title">마이페이지</span></div>
  <div class="my-hero"><div class="my-hero-title">내 매물 관리</div><div class="my-hero-sub">등록한 매물과 문의 현황을 확인하세요</div></div>
  <div class="my-stats"><div class="my-stat"><div class="my-stat-n">2</div><div class="my-stat-l">등록 매물</div></div><div class="my-stat"><div class="my-stat-n">28</div><div class="my-stat-l">오늘 조회</div></div><div class="my-stat"><div class="my-stat-n">5</div><div class="my-stat-l">문의 수</div></div></div>
  <div class="my-list">
    <div style="font-size:11px;color:var(--i3);letter-spacing:1.5px;margin-bottom:12px;text-transform:uppercase;font-weight:600;">등록한 매물</div>
    <div class="my-item"><div class="my-thumb"></div><div class="my-info"><div class="my-title">정육점 양도 — 경기 안양시</div><div class="my-sub">권리금 2,500만원 · 3일 전 등록</div><span class="my-badge">노출 중</span></div><div class="my-btns"><button class="btn-edit">수정</button><button class="btn-edit btn-del">삭제</button></div></div>
    <div class="my-item"><div class="my-thumb"></div><div class="my-info"><div class="my-title">정육 냉장 쇼케이스 2m</div><div class="my-sub">180만원 · 오늘 등록</div><span class="my-badge">노출 중</span></div><div class="my-btns"><button class="btn-edit">수정</button><button class="btn-edit btn-del">삭제</button></div></div>
  </div>
</div>

<!-- 모바일 탭 -->
<div class="mobile-tab">
  <button class="mtab on" id="mt-h" onclick="go('h')"><span class="mtab-ico">🏠</span><span class="mtab-txt">홈</span></button>
  <button class="mtab" id="mt-c" onclick="go('c')"><span class="mtab-ico">📊</span><span class="mtab-txt">컨설팅</span></button>
  <button class="mtab" id="mt-r" onclick="go('r')"><span class="mtab-ico">✚</span><span class="mtab-txt">등록</span></button>
  <button class="mtab" id="mt-sup" onclick="go('sup')"><span class="mtab-ico">🏭</span><span class="mtab-txt">공급사</span></button>
  <button class="mtab" id="mt-m" onclick="go('m')"><span class="mtab-ico">👤</span><span class="mtab-txt">마이</span></button>
</div>

<script>
const D=[
  {t:'s',tag:'상가·권리금',tc:'tag-store',ti:'정육점 양도 — 단골 다수',su:'49㎡ · 잔여 2년 · 장비 포함',pr:'권리금 2,500만원',p2:'보증금 1,500',lo:'경기 안양시',ag:'오늘',nw:true,pm:true},
  {t:'i',tag:'집기·장비',tc:'tag-item',ti:'정육 냉장 쇼케이스 2m',su:'2년 사용 · 직거래 가능',pr:'180만원',p2:'',lo:'서울 은평구',ag:'1일 전',nw:false,pm:false},
  {t:'s',tag:'상가·권리금',tc:'tag-store',ti:'삼겹살 전문점 양도',su:'66㎡ · 월세 150만',pr:'권리금 3,500만원',p2:'보증금 2,000',lo:'서울 마포구',ag:'2일 전',nw:false,pm:false},
  {t:'i',tag:'집기·장비',tc:'tag-item',ti:'고기절단기 반자동',su:'업소용 · 상태 양호',pr:'95만원',p2:'',lo:'경기 수원시',ag:'3일 전',nw:false,pm:false},
  {t:'s',tag:'상가·권리금',tc:'tag-store',ti:'한우 전문점 양도',su:'82㎡ · 프리미엄 인테리어',pr:'권리금 8,000만원',p2:'보증금 5,000',lo:'서울 강남구',ag:'4일 전',nw:false,pm:false},
  {t:'f',tag:'식자재·재고',tc:'tag-food',ti:'냉동 삼겹살 재고 처분',su:'200kg · 유통기한 2개월',pr:'시세 60%',p2:'',lo:'인천 남동구',ag:'오늘',nw:true,pm:false},
];

function renderListings(items){
  const g=document.getElementById('listing-grid');
  if(!g)return;
  g.innerHTML=items.map(d=>`
    <div class="lc">
      <div class="lc-thumb">
        <div class="lc-thumb-inner"></div>
        ${d.pm?'<div class="lc-premium">상단노출</div>':''}
      </div>
      <div class="lc-body">
        <div class="lc-tags">
          <span class="lc-tag ${d.tc}">${d.tag}</span>
          ${d.nw?'<span class="lc-tag tag-new">NEW</span>':''}
        </div>
        <div class="lc-title">${d.ti}</div>
        <div class="lc-sub">${d.su}</div>
        <div class="lc-price">${d.pr} <small>${d.p2}</small></div>
        <div class="lc-foot"><span class="lc-loc">${d.lo}</span><span class="lc-ago">${d.ag}</span></div>
      </div>
    </div>`).join('');
}
renderListings(D);

function filterL(el,t){
  document.querySelectorAll('.filter-chips .fchip').forEach(e=>e.classList.remove('on'));
  el.classList.add('on');
  renderListings(t==='a'?D:D.filter(d=>d.t===t));
}

function go(p){
  document.querySelectorAll('.pg').forEach(e=>e.classList.remove('on'));
  const el=document.getElementById('pg-'+p);
  if(el)el.classList.add('on');
  ['h','c','sup','x','s','m'].forEach(id=>{
    const nb=document.getElementById('nb-'+id);
    if(nb)nb.classList.toggle('on',id===p);
  });
  ['h','c','r','sup','m'].forEach(id=>{
    const mt=document.getElementById('mt-'+id);
    if(mt)mt.classList.toggle('on',id===p);
  });
  document.documentElement.scrollTop=0;
  document.body.scrollTop=0;
}

function setTab(el,i){
  document.querySelectorAll('.tab-btn').forEach(e=>e.classList.remove('on'));
  el.classList.add('on');
  document.getElementById('tab-0').style.display=i===0?'block':'none';
  document.getElementById('tab-1').style.display=i===1?'block':'none';
}

function setCalc(el,i){
  document.querySelectorAll('.ct').forEach(e=>e.classList.remove('on'));
  el.classList.add('on');
  ['calc-0','calc-1','calc-2'].forEach((id,j)=>{
    const c=document.getElementById(id);
    if(c)c.style.display=j===i?'block':'none';
  });
}

function selType(i){
  [0,1,2].forEach(j=>{
    const el=document.getElementById('t'+j);
    if(el)el.classList.toggle('on',j===i);
  });
}

function setFilter(el){
  document.querySelectorAll('.filter-bar .fchip').forEach(e=>e.classList.remove('on'));
  el.classList.add('on');
}

function cC(){
  const sv=+document.getElementById('s').value||0,cv=+document.getElementById('c').value||0,qv=+document.getElementById('q').value||0,ev=+document.getElementById('e').value||0;
  if(!sv)return;
  const cr=cv/sv*100,mr=100-cr-ev,pr=Math.round(sv*(mr/100));
  document.getElementById('r1').textContent=cr.toFixed(1)+'%';
  document.getElementById('r2').textContent=mr.toFixed(1)+'%';
  document.getElementById('r3').textContent=pr.toLocaleString()+'원';
  document.getElementById('r4').textContent=(pr*qv).toLocaleString()+'원';
}
function cB(){
  const f=+document.getElementById('bf').value||0,a=+document.getElementById('ba').value||0,r=+document.getElementById('br').value||0,co=(100-r)/100;
  if(!co||!a)return;
  const bs=Math.round(f/co),bd=Math.round(bs/30);
  document.getElementById('b1').textContent=bs.toLocaleString()+'원';
  document.getElementById('b2').textContent=bd.toLocaleString()+'원';
  document.getElementById('b3').textContent=(bd/a).toFixed(1)+'팀';
  document.getElementById('b4').textContent=(co*100).toFixed(1)+'%';
}
function cM(){
  const i=+document.getElementById('mi').value||0,t=+document.getElementById('mt').value||35,c=+document.getElementById('mc').value||0,p=Math.round(i/(t/100));
  document.getElementById('m1').textContent=p.toLocaleString()+'원';
  document.getElementById('m2').textContent=c?((p/c-1)*100).toFixed(1)+'%':'—';
  document.getElementById('m3').textContent=(p-i).toLocaleString()+'원';
  document.getElementById('m4').textContent=Math.round(p*.93).toLocaleString()+'~'+Math.round(p*1.07).toLocaleString()+'원';
}
cC();cB();cM();
</script>
</body>
</html>
